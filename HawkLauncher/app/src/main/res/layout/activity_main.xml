<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="[SYS:OK]"
            android:textColor="#00FF9F"
            android:textSize="10sp"
            android:fontFamily="monospace"/>

        <TextView
            android:id="@+id/tv_battery"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="[BAT:--]"
            android:textColor="#FFAA00"
            android:textSize="10sp"
            android:fontFamily="monospace"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#00FF9F33"/>

    <TextView
        android:id="@+id/tv_time"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="00:00:00"
        android:textColor="#00FF9F"
        android:textSize="36sp"
        android:fontFamily="monospace"
        android:gravity="center"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="2dp"/>

    <TextView
        android:id="@+id/tv_date"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="MON 01 JAN 2025"
        android:textColor="#00FF9F88"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:gravity="center"
        android:layout_marginBottom="2dp"/>

    <TextView
        android:id="@+id/tv_ram"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="[RAM: --/--MB]"
        android:textColor="#00FF9F66"
        android:textSize="10sp"
        android:fontFamily="monospace"
        android:gravity="center"
        android:layout_marginBottom="8dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#00FF9F33"/>

    <ScrollView
        android:id="@+id/scroll_terminal"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none"
        android:overScrollMode="never"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_terminal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#00FF9F"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:lineSpacingExtra="2dp"/>

            <ListView
                android:id="@+id/lv_apps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:divider="#00FF9F11"
                android:dividerHeight="1dp"
                android:scrollbars="none"
                android:overScrollMode="never"
                android:nestedScrollingEnabled="false"
                android:background="#000000"/>

        </LinearLayout>
    </ScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#00FF9F33"/>

    <TextView
        android:id="@+id/tv_prompt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="hawk@os:~# _"
        android:textColor="#00FF9F"
        android:textSize="13sp"
        android:fontFamily="monospace"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/et_search"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="type command or app name..."
        android:textColorHint="#00FF9F44"
        android:textColor="#00FF9F"
        android:textSize="13sp"
        android:fontFamily="monospace"
        android:background="@drawable/input_bg"
        android:padding="10dp"
        android:imeOptions="actionDone"
        android:inputType="text"
        android:maxLines="1"/>

</LinearLayout>
