<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:padding="12dp">

    <LinearLayout
        android:id="@+id/hud_top"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView android:id="@+id/tv_status" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="[SYS:OK]" android:textColor="#00FF9F" android:fontFamily="monospace" android:textSize="10sp"/>
            <TextView android:id="@+id/tv_net_speed" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="[NET: 0 KB/s]" android:textColor="#00BFFF" android:fontFamily="monospace" android:textSize="10sp" android:layout_marginEnd="8dp"/>
            <TextView android:id="@+id/tv_battery" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="[BAT: 100%]" android:textColor="#FFAA00" android:fontFamily="monospace" android:textSize="10sp"/>
        </LinearLayout>

        <TextView android:id="@+id/tv_time" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="00:00" android:textColor="#00FF9F" android:textSize="48sp" android:fontFamily="monospace"/>
        <TextView android:id="@+id/tv_ram_cpu" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="[RAM: 0/0MB] [CPU: 0%]" android:textColor="#00FF9F" android:fontFamily="monospace" android:textSize="10sp"/>
    </LinearLayout>

    <ListView
        android:id="@+id/lv_apps"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/hud_top"
        android:layout_above="@+id/terminal_input"
        android:divider="@null"
        android:scrollbars="none" />

    <LinearLayout
        android:id="@+id/terminal_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:paddingTop="8dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="hawk@os:~# "
            android:textColor="#00FF9F"
            android:fontFamily="monospace"/>
        <EditText
            android:id="@+id/et_search"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@null"
            android:textColor="#00FF9F"
            android:fontFamily="monospace"
            android:hint="type command..."
            android:textColorHint="#3300FF9F"
            android:imeOptions="actionGo"
            android:inputType="textNoSuggestions"/>
    </LinearLayout>
</RelativeLayout>
