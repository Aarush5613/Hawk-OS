<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:padding="16dp">

    <LinearLayout
        android:id="@+id/hud_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <TextView android:id="@+id/tv_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#00FF9F" android:textSize="42sp" android:fontFamily="monospace"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content">
            <TextView android:id="@+id/tv_ram" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textColor="#00FF9F" android:fontFamily="monospace" android:textSize="10sp"/>
            <TextView android:id="@+id/tv_net" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#00BFFF" android:fontFamily="monospace" android:textSize="10sp" android:text="[NET: 0 KB/s]"/>
        </LinearLayout>
    </LinearLayout>

    <ListView
        android:id="@+id/lv_apps"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/hud_container"
        android:layout_above="@+id/terminal_bar"
        android:divider="@null"
        android:scrollbars="none" />

    <LinearLayout
        android:id="@+id/terminal_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#111111"
        android:padding="8dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="hawk@os:~$ " android:textColor="#00FF9F" android:fontFamily="monospace"/>
        <EditText
            android:id="@+id/et_search"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@null"
            android:textColor="#FFFFFF"
            android:fontFamily="monospace"
            android:hint="_"
            android:textColorHint="#4400FF9F"/>
    </LinearLayout>
</RelativeLayout>
